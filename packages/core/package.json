{
  "name": "@crosshair/core",
  "version": "0.1.1",
  "type": "module",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mhandresen/crosshair.git",
    "directory": "packages/core"
  },
  "description": "Core library for Crosshair — testing MCP server tool definitions and selection behavior.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "llm",
    "ai",
    "testing",
    "tool-calling",
    "anthropic",
    "claude",
    "evals"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "c12": "4.0.0-beta.5",
    "jiti": "^2.7.0",
    "picocolors": "^1.1.1",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0"
  }
}
